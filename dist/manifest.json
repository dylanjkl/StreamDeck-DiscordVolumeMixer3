{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "icons/actions/openmixer",
      "Name": "Discord Volume Mixer",
      "States": [
        {
          "Image": "icons/icons8_discord_new_72px",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": false,
      "Tooltip": "Opens a mixer for Discord voice chat",
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "UUID": "dylanjkl.discordmixer.openmixer"
    },
    {
      "Icon": "icons/actions/back",
      "Name": "[DVM] Back",
      "States": [
        {
          "Image": "icons/icons8_arrow_up_72px",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Closes the volume mixer",
      "UUID": "dylanjkl.discordmixer.back"
    },
    {
      "Icon": "icons/actions/user",
      "Name": "[DVM] Voice channel member",
      "States": [
        {
          "Image": "icons/noicon",
          "ShowTitle": true,
          "TitleAlignment": "middle",
          "FontFamily": "Verdana",
          "FontSize": 8
        },
        {
          "Image": "icons/noicon",
          "ShowTitle": true,
          "TitleAlignment": "middle",
          "FontFamily": "Verdana",
          "FontSize": 8
        }
      ],
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "Icon": "icons/icons8_user_72px",
        "TriggerDescription": {
          "Rotate": "Change user volume",
          "Push": "Configurable",
          "Touch": "Configurable"
        }
      },
      "UserTitleEnabled": false,
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "Tooltip": "Shows user avatar, status, volume.",
      "UUID": "dylanjkl.discordmixer.user"
    },
    {
      "Icon": "icons/actions/volumeup",
      "Name": "[DVM] Voice channel member volume up",
      "States": [
        {
          "Image": "icons/icons8_plus_math_72px",
          "ShowTitle": false
        },
        {
          "Image": "icons/noicon",
          "ShowTitle": false
        }
      ],
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "Tooltip": "Increase volume",
      "UUID": "dylanjkl.discordmixer.volumeup"
    },
    {
      "Icon": "icons/actions/volumedown",
      "Name": "[DVM] Voice channel member volume down",
      "States": [
        {
          "Image": "icons/icons8_minus_72px",
          "ShowTitle": false
        },
        {
          "Image": "icons/noicon",
          "ShowTitle": false
        }
      ],
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "Tooltip": "Decrease volume",
      "UUID": "dylanjkl.discordmixer.volumedown"
    },
    {
      "Icon": "icons/actions/nextpage",
      "Name": "[DVM] Next page",
      "States": [
        {
          "Image": "icons/icons8_sort_right_72px",
          "ShowTitle": true,
          "TitleAlignment": "top",
          "FontFamily": "Verdana",
          "FontSize": 8
        },
        {
          "Image": "icons/noicon",
          "ShowTitle": true,
          "TitleAlignment": "top",
          "FontFamily": "Verdana",
          "FontSize": 8
        }
      ],
      "UserTitleEnabled": false,
      "Tooltip": "Next page",
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "UUID": "dylanjkl.discordmixer.nextpage"
    },
    {
      "Icon": "icons/actions/previouspage",
      "Name": "[DVM] Previous page",
      "States": [
        {
          "Image": "icons/icons8_sort_left_72px",
          "ShowTitle": true,
          "TitleAlignment": "top",
          "FontFamily": "Verdana",
          "FontSize": 8
        },
        {
          "Image": "icons/noicon",
          "ShowTitle": true,
          "TitleAlignment": "top",
          "FontFamily": "Verdana",
          "FontSize": 8
        }
      ],
      "UserTitleEnabled": false,
      "Tooltip": "Previous page",
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "UUID": "dylanjkl.discordmixer.previouspage"
    },
    {
      "Icon": "icons/actions/microphone",
      "Name": "[DVM] Mute/unmute microphone",
      "States": [
        {
          "Image": "icons/icons8_microphone_72px",
          "ShowTitle": false
        },
        {
          "Image": "icons/icons8_block_microphone_72px",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Mute/unmute microphone",
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "UUID": "dylanjkl.discordmixer.microphone"
    },
    {
      "Icon": "icons/actions/deafen",
      "Name": "[DVM] Mute/unmute audio (deafen)",
      "States": [
        {
          "Image": "icons/icons8_speaker_72px",
          "ShowTitle": false
        },
        {
          "Image": "icons/icons8_no_audio_72px",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Mute/unmute audio (deafen)",
      "PropertyInspectorPath": "qtstreamdeck2/propertyinspector.html",
      "UUID": "dylanjkl.discordmixer.deafen"
    }
  ],
  "SDKVersion": 3,
  "Author": "dylanjkl",
  "CodePath": "bin/streamdeck-discordmixer.exe",
  "Description": "Provides a mixer for Discord voice chat that allows adjusting volume for individual users.\nThis application uses Icons8 icons (https://icons8.com)",
  "Category": "Discord Volume Mixer 3",
  "CategoryIcon": "icons/category",
  "Name": "Discord Volume Mixer 3",
  "Icon": "icons/plugin",
  "URL": "https://github.com/dylanjkl/StreamDeck-DiscordVolumeMixer3",
  "SupportURL": "https://github.com/dylanjkl/StreamDeck-DiscordVolumeMixer3/issues",
  "UUID": "dylanjkl.discordmixer",
  "Version": "3.0.0.0",
  "Profiles": [
    {
      "Name": "Discord Volume Mixer",
      "DeviceType": 0
    },
    {
      "Name": "Discord Volume Mixer",
      "DeviceType": 3
    },
    {
      "Name": "Discord Volume Mixer XL",
      "DeviceType": 2
    },
    {
      "Name": "Discord Volume Mixer Mini",
      "DeviceType": 1
    },
    {
      "Name": "Discord Volume Mixer+",
      "DeviceType": 7
    }
  ],
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Software": {
    "MinimumVersion": "7.4"
  }
}
